# Supabase — required at build time and runtime.
# Copy this file to `.env.local` and fill in the values from
# https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — server-only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Site URL — used by server actions to build OAuth callback URLs.
# In production, set this to the deployed origin (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional — Personal Access Token for `npx supabase gen types`.
# Required only locally; do NOT set in Vercel.
SUPABASE_ACCESS_TOKEN=sbp_...

# Optional — project ref for `supabase link`.
SUPABASE_PROJECT_REF=YOUR-PROJECT-REF
